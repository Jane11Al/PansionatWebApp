### POST создать связь
POST {{baseUrl}}/api/guardian-pupils
Content-Type: {{contentType}}

{
  "guardianFullName": "Сидорова Мария Ивановна",
  "personalFileNumber": 1001
}

### PUT обновить связь
PUT {{baseUrl}}/api/guardian-pupils/1001
Content-Type: {{contentType}}

{
  "guardianFullName": "Сидорова Мария Ивановна",
  "personalFileNumber": 1001
}

### DELETE удалить связь
DELETE {{baseUrl}}/api/guardian-pupils/1001


###############################################
# 7. Program (Программа)
###############################################

### GET все программы
GET {{baseUrl}}/api/programs

### GET программа по коду
GET {{baseUrl}}/api/programs/1

### POST создать программу
POST {{baseUrl}}/api/programs
Content-Type: {{contentType}}

{
  "code": 1,
  "name": "Адаптированная основная общеобразовательная программа"
}

### PUT обновить программу
PUT {{baseUrl}}/api/programs/1
Content-Type: {{contentType}}

{
  "code": 1,
  "name": "АООП (вариант 1)"
}

### DELETE удалить программу
DELETE {{baseUrl}}/api/programs/1


###############################################
# 8. SubjectArea (Предметная область)
###############################################

### GET все предметные области
GET {{baseUrl}}/api/subject-areas

### GET область по коду
GET {{baseUrl}}/api/subject-areas/10

### POST создать область
POST {{baseUrl}}/api/subject-areas
Content-Type: {{contentType}}

{
  "code": 10,
  "name": "Язык и речевая практика"
}

### PUT обновить область
PUT {{baseUrl}}/api/subject-areas/10
Content-Type: {{contentType}}

{
  "code": 10,
  "name": "Русский язык и речевая практика"
}

### DELETE удалить область
DELETE {{baseUrl}}/api/subject-areas/10


###############################################
# 9. MedicalEquipment (Медоборудование)
###############################################

### GET всё оборудование
GET {{baseUrl}}/api/medical-equipments

### GET оборудование по инвентарному номеру
GET {{baseUrl}}/api/medical-equipments/5001

### POST создать оборудование
POST {{baseUrl}}/api/medical-equipments
Content-Type: {{contentType}}

{
  "inventoryNumber": 5001,
  "name": "Ингалятор компрессорный",
  "issueDate": "2023-09-01",
  "personalFileNumber": 1001
}

### PUT обновить оборудование
PUT {{baseUrl}}/api/medical-equipments/5001
Content-Type: {{contentType}}

{
  "inventoryNumber": 5001,
  "name": "Ингалятор ультразвуковой",
  "issueDate": "2023-09-01",
  "personalFileNumber": 1001
}

### DELETE удалить оборудование
DELETE {{baseUrl}}/api/medical-equipments/5001


###############################################
# 10. IndividualProgram (Индивидуальная программа)
###############################################

### GET все индивидуальные программы
GET {{baseUrl}}/api/individual-programs

### GET по составному ключу (год/код программы)
GET {{baseUrl}}/api/individual-programs/2024/1

### POST создать индивидуальную программу
POST {{baseUrl}}/api/individual-programs
Content-Type: {{contentType}}

{
  "year": 2024,
  "programCode": 1
}

### DELETE удалить индивидуальную программу
DELETE {{baseUrl}}/api/individual-programs/2024/1


###############################################
# 11. PupilEducation (Обучение воспитанника)
###############################################

### GET все обучения
GET {{baseUrl}}/api/pupil-educations

### GET обучение по коду
GET {{baseUrl}}/api/pupil-educations/3001

### POST создать обучение
POST {{baseUrl}}/api/pupil-educations
Content-Type: {{contentType}}

{
  "code": 3001,
  "year": 2024,
  "programCode": 1,
  "teacherFullName": "Петрова Анна Сергеевна",
  "personalFileNumber": 1001
}

### PUT обновить обучение
PUT {{baseUrl}}/api/pupil-educations/3001
Content-Type: {{contentType}}

{
  "code": 3001,
  "year": 2024,
  "programCode": 1,
  "teacherFullName": "Петрова Анна Сергеевна",
  "personalFileNumber": 1001
}

### DELETE удалить обучение
DELETE {{baseUrl}}/api/pupil-educations/3001


###############################################
# 12. Subject (Учебный предмет)
###############################################

### GET все предметы
GET {{baseUrl}}/api/subjects

### GET предмет по составному ключу (название/код области)
GET {{baseUrl}}/api/subjects/Русский%20язык/10

### POST создать предмет
POST {{baseUrl}}/api/subjects
Content-Type: {{contentType}}

{
  "name": "Русский язык",
  "subjectAreaCode": 10,
  "hours": 68,
  "programCode": 1,
  "year": 2024
}

### PUT обновить предмет
PUT {{baseUrl}}/api/subjects/Русский%20язык/10
Content-Type: {{contentType}}

{
  "name": "Русский язык",
  "subjectAreaCode": 10,
  "hours": 70,
  "programCode": 1,
  "year": 2024
}

### DELETE удалить предмет
DELETE {{baseUrl}}/api/subjects/Русский%20язык/10


###############################################
# 13. SubjectResult (Результат изучения предмета)
###############################################

### GET все результаты
GET {{baseUrl}}/api/subject-results

### GET результат по составному ключу
GET {{baseUrl}}/api/subject-results/Русский%20язык/10/3001

### POST создать результат
POST {{baseUrl}}/api/subject-results
Content-Type: {{contentType}}

{
  "subjectName": "Русский язык",
  "subjectAreaCode": 10,
  "educationCode": 3001,
  "goalDescription": "Формирование навыков чтения и письма",
  "resultDescription": "Читает по слогам, пишет печатными буквами"
}

### PUT обновить результат
PUT {{baseUrl}}/api/subject-results/Русский%20язык/10/3001
Content-Type: {{contentType}}

{
  "subjectName": "Русский язык",
  "subjectAreaCode": 10,
  "educationCode": 3001,
  "goalDescription": "Формирование навыков чтения и письма",
  "resultDescription": "Читает целыми словами, пишет прописными буквами"
}

### DELETE удалить результат
DELETE {{baseUrl}}/api/subject-results/Русский%20язык/10/3001


