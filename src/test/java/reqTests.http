> {% client.global.set("authToken", response.body.token); %}

###############################################
# Воспитанник (Pupil)
###############################################

### Получить всех воспитанников
GET {{baseUrl}}/api/pupils
Authorization: Bearer {{authToken}}

### Получить воспитанника по ID (подставьте существующий ID)
GET {{baseUrl}}/api/pupils/1
Authorization: Bearer {{authToken}}

### Создать воспитанника
POST {{baseUrl}}/api/pupils
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "personalFileNumber": 1001,
  "fullName": "Петров Петр Петрович",
  "birthDate": "2012-03-15",
  "gender": "М",
  "mainDiagnosis": "F70.0"
}

### Обновить воспитанника (ID = 1)
PUT {{baseUrl}}/api/pupils/1
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "personalFileNumber": 1001,
  "fullName": "Петров Петр Петрович (обновлено)",
  "birthDate": "2012-03-15",
  "gender": "М",
  "mainDiagnosis": "F71.0"
}

### Удалить воспитанника (ID = 1)
DELETE {{baseUrl}}/api/pupils/1
Authorization: Bearer {{authToken}}

###############################################
# Диагноз (Diagnosis)
###############################################

### Получить все диагнозы
GET {{baseUrl}}/api/diagnoses
Authorization: Bearer {{authToken}}

### Создать диагноз
POST {{baseUrl}}/api/diagnoses
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "code": "F70.0",
  "name": "Умственная отсталость легкой степени"
}

### Получить диагноз по ID
GET {{baseUrl}}/api/diagnoses/1
Authorization: Bearer {{authToken}}

### Обновить диагноз (ID = 1)
PUT {{baseUrl}}/api/diagnoses/1
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "code": "F70.0",
  "name": "Легкая умственная отсталость"
}

### Удалить диагноз
DELETE {{baseUrl}}/api/diagnoses/1
Authorization: Bearer {{authToken}}

###############################################
# Связь Диагноз-Воспитанник (DiagnosisPupil)
###############################################

### Получить все связи
GET {{baseUrl}}/api/diagnosis-pupils
Authorization: Bearer {{authToken}}

### Создать связь (предварительно должны существовать Pupil с ID=1 и Diagnosis с ID=1)
POST {{baseUrl}}/api/diagnosis-pupils
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "diagnosisId": 1,
  "pupilId": 1
}

### Получить связь по ID
GET {{baseUrl}}/api/diagnosis-pupils/1
Authorization: Bearer {{authToken}}

### Обновить связь
PUT {{baseUrl}}/api/diagnosis-pupils/1
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "diagnosisId": 2,
  "pupilId": 1
}

### Удалить связь
DELETE {{baseUrl}}/api/diagnosis-pupils/1
Authorization: Bearer {{authToken}}

