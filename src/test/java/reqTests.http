### Переменные (настройте при необходимости)
@baseUrl = http://localhost:8080
@contentType = application/json

###############################################
# 1. Pupil (Воспитанник)
###############################################

### GET все воспитанники
GET {{baseUrl}}/api/pupils

### GET воспитанник по ID
GET {{baseUrl}}/api/pupils/1001

### POST создать воспитанника
POST {{baseUrl}}/api/pupils
Content-Type: {{contentType}}

{
  "personalFileNumber": 1001,
  "fullName": "Иванов Иван Иванович",
  "birthDate": "2010-05-15",
  "gender": "М",
  "mainDiagnosis": "F70.0"
}

### PUT обновить воспитанника
PUT {{baseUrl}}/api/pupils/1001
Content-Type: {{contentType}}

{
  "personalFileNumber": 1001,
  "fullName": "Иванов Иван Петрович",
  "birthDate": "2010-05-15",
  "gender": "М",
  "mainDiagnosis": "F71.0"
}

### DELETE удалить воспитанника
DELETE {{baseUrl}}/api/pupils/1001


###############################################
# 2. Diagnosis (Диагноз)
###############################################

### GET все диагнозы
GET {{baseUrl}}/api/diagnoses

### GET диагноз по коду
GET {{baseUrl}}/api/diagnoses/F70.0

### POST создать диагноз
POST {{baseUrl}}/api/diagnoses
Content-Type: {{contentType}}

{
  "code": "F70.0",
  "name": "Умственная отсталость легкой степени"
}

### PUT обновить диагноз
PUT {{baseUrl}}/api/diagnoses/F70.0
Content-Type: {{contentType}}

{
  "code": "F70.0",
  "name": "Легкая умственная отсталость"
}

### DELETE удалить диагноз
DELETE {{baseUrl}}/api/diagnoses/F70.0


###############################################
# 3. DiagnosisPupil (Диагноз воспитанника)
###############################################

### GET все связи диагноз-воспитанник
GET {{baseUrl}}/api/diagnosis-pupils

### GET связь по составному ключу
GET {{baseUrl}}/api/diagnosis-pupils/F70.0/1001

### POST создать связь
POST {{baseUrl}}/api/diagnosis-pupils
Content-Type: {{contentType}}

{
  "diagnosisCode": "F70.0",
  "personalFileNumber": 1001
}

### DELETE удалить связь
DELETE {{baseUrl}}/api/diagnosis-pupils/F70.0/1001


###############################################
# 4. Teacher (Педагог)
###############################################

### GET все педагоги
GET {{baseUrl}}/api/teachers

### GET педагог по ФИО (URL-encoded)
GET {{baseUrl}}/api/teachers/Петрова%20Анна%20Сергеевна

### POST создать педагога
POST {{baseUrl}}/api/teachers
Content-Type: {{contentType}}

{
  "fullName": "Петрова Анна Сергеевна",
  "birthDate": "1985-03-20",
  "contactInfo": "+7-999-123-45-67",
  "position": "Учитель начальных классов"
}

### PUT обновить педагога
PUT {{baseUrl}}/api/teachers/Петрова%20Анна%20Сергеевна
Content-Type: {{contentType}}

{
  "fullName": "Петрова Анна Сергеевна",
  "birthDate": "1985-03-20",
  "contactInfo": "+7-999-123-45-67",
  "position": "Старший учитель"
}

### DELETE удалить педагога
DELETE {{baseUrl}}/api/teachers/Петрова%20Анна%20Сергеевна


###############################################
# 5. Guardian (Опекун)
###############################################

### GET все опекуны
GET {{baseUrl}}/api/guardians

### GET опекун по ФИО
GET {{baseUrl}}/api/guardians/Сидорова%20Мария%20Ивановна

### POST создать опекуна
POST {{baseUrl}}/api/guardians
Content-Type: {{contentType}}

{
  "fullName": "Сидорова Мария Ивановна",
  "contactInfo": "+7-888-555-33-22",
  "address": "г. Москва, ул. Ленина, д. 10, кв. 5",
  "gender": "Ж",
  "birthDate": "1975-08-12"
}

### PUT обновить опекуна
PUT {{baseUrl}}/api/guardians/Сидорова%20Мария%20Ивановна
Content-Type: {{contentType}}

{
  "fullName": "Сидорова Мария Ивановна",
  "contactInfo": "+7-888-555-33-22",
  "address": "г. Москва, ул. Пушкина, д. 5, кв. 12",
  "gender": "Ж",
  "birthDate": "1975-08-12"
}

### DELETE удалить опекуна
DELETE {{baseUrl}}/api/guardians/Сидорова%20Мария%20Ивановна


###############################################
# 6. GuardianPupil (Опекун воспитанника)
###############################################

### GET все связи опекун-воспитанник
GET {{baseUrl}}/api/guardian-pupils

### GET связь по номеру дела воспитанника
